{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Atari XEX",
            "type": "shell",
            "command": "cl65",
            "args": [
                "-t",
                "atari",
                "-O",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.xex"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}